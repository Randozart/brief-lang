# This is a Brief program demonstrating comments
# Comments are preserved during annotation

# Entry point - fires immediately
rct txn main [true][done == true] {
  init();
  setup();
  process();
  &done = true;
  term;
};

# Initialize the system
defn init(): Void [true][true] {
  term;
};

# Setup resources
defn setup(): Void [true][true] {
  term;
};

# Main processing logic
defn process(): Void [true][true] {
  term;
};

let done: Bool = false;
