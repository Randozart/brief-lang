# Entry point - fires immediately
rct txn main [true][done == true] {
  init();
  setup();
  process();
  &done = true;
  term;
};

defn init(): Void [true][true] {
  # Initialization logic
  term;
};

defn setup(): Void [true][true] {
  # Setup logic
  term;
};

defn process(): Void [true][true] {
  # Processing logic
  term;
};

let done: Bool = false;
