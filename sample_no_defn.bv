import std.io;

sig fetch: String -> Data | Error;
sig get_id: String -> Int[~0];
let data: Data;
let count: Int = 0;

txn load [~/data] {
  let res = fetch("api");
  Data(d) = res; &data = d; term;
  Error(e) = res; escape;
};

async txn process [data != null][count == @count + 1] {
  &count = count + 1;
  term;
};
