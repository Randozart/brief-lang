let counter: Int = 0;
let started: Bool = false;
let finished: Bool = false;

rct txn start [counter == 0][started == true] {
  &started = true;
  term;
};

rct txn increment [started == true && finished == false && counter < 3][counter == @counter + 1] {
  &counter = counter + 1;
  term;
};

rct txn finish [counter == 3][finished == true] {
  &finished = true;
  term;
};
