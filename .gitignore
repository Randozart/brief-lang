# Brief Compiler

# ============================================
# SPECS
# ============================================
# spec/ is NOT ignored - we track specification files
# Only ignore generated spec outputs
spec/*.pdf
spec/*.html

# ============================================
# TESTS
# ============================================
tests/

# ============================================
# TEST PROJECTS (generated by `brief init`)
# ============================================
test-project/

# ============================================
# RUST BUILD ARTIFACTS
# ============================================
/target/
**/*.rs.bk
Cargo.lock

# ============================================
# GENERATED FILES
# ============================================
*.bc.json
test-*.js
test-*.js.map
test-*.d.ts
test-*.d.ts.map

# ============================================
# NODE/JAVASCRIPT (legacy tooling)
# ============================================
node_modules/
package-lock.json
package.json
!syntax-highlighter/package.json
tsconfig.json
dist/

# ============================================
# IMAGES & LOGOS
# ============================================
*.png
*.gif
*.svg

# ============================================
# EDITOR & IDE
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================
# ENVIRONMENT & SECRETS
# ============================================
.env
.env.local
*.log
counter-build/
